<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.odoo_ai_chatbot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="AI Assistant" string="AI Assistant" name="odoo_ai_chatbot">
                    <block title="AI Provider" name="ai_provider_setting_container">
                        <setting string="Provider" help="Which AI backend the assistant talks to.">
                            <field name="ai_provider" widget="radio"/>
                        </setting>

                        <setting string="Connection" help="Model, key and endpoint for the selected provider.">
                            <div class="content-group">
                                <div class="row mt16" invisible="ai_provider == 'bedrock'">
                                    <label for="ai_api_key" string="API Key" class="col-lg-4 o_light_label"/>
                                    <field name="ai_api_key" password="True" class="col-lg-8"
                                           placeholder="Optional for a local Ollama server"/>
                                </div>
                                <div class="row mt8" invisible="ai_provider == 'bedrock'">
                                    <label for="ai_model" string="Model" class="col-lg-4 o_light_label"/>
                                    <field name="ai_model" class="col-lg-8"
                                           placeholder="e.g. gpt-4o-mini / claude-3-5-sonnet-latest / qwen3:latest"/>
                                </div>
                                <div class="row mt8" invisible="ai_provider not in ('ollama', 'openai_compatible')">
                                    <label for="ai_base_url" string="Base URL" class="col-lg-4 o_light_label"/>
                                    <field name="ai_base_url" class="col-lg-8"
                                           placeholder="http://localhost:11434 (Ollama) or your endpoint URL"/>
                                </div>
                            </div>
                        </setting>

                        <setting string="Amazon Bedrock" help="AWS credentials for the Bedrock provider."
                                 invisible="ai_provider != 'bedrock'">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="bedrock_aws_access_key" string="Access Key" class="col-lg-4 o_light_label"/>
                                    <field name="bedrock_aws_access_key" password="True" class="col-lg-8"/>
                                </div>
                                <div class="row mt8">
                                    <label for="bedrock_aws_secret_key" string="Secret Key" class="col-lg-4 o_light_label"/>
                                    <field name="bedrock_aws_secret_key" password="True" class="col-lg-8"/>
                                </div>
                                <div class="row mt8">
                                    <label for="bedrock_region" string="Region" class="col-lg-4 o_light_label"/>
                                    <field name="bedrock_region" class="col-lg-8"/>
                                </div>
                                <div class="row mt8">
                                    <label for="ai_model" string="Model ID" class="col-lg-4 o_light_label"/>
                                    <field name="ai_model" class="col-lg-8"
                                           placeholder="e.g. anthropic.claude-3-5-sonnet-20240620-v1:0"/>
                                </div>
                            </div>
                        </setting>

                        <setting string="System Prompt" help="Advanced — override the assistant's built-in instructions. Leave blank to use the default."
                                 class="col-12 col-lg-12">
                            <div class="content-group mt-2">
                                <field name="ai_system_prompt" widget="text" class="w-100" placeholder="Leave blank to use the built-in instructions."/>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
